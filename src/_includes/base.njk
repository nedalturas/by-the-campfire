<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - By the Campfire</title>
    <meta name="description" content="A multi-authored blog for random literature">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,300;0,400;0,700;1,300;1,400&family=Outfit:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
    <div class="fire-particles" aria-hidden="true"></div>
    <header class="site-header">
        <div class="container">
            <a href="/" class="logo">
                <span class="logo-icon">🔥</span>
                By the Campfire
            </a>
            <nav class="site-nav">
                <a href="/">Home</a>
                <a href="/tags/">Tags</a>
            </nav>
        </div>
    </header>

    <main class="container">
        {{ content | safe }}
    </main>

    <footer class="site-footer">
        <div class="container">
            <p>&copy; {% if page.date %}{{ page.date | postDate | truncate(4, true, "") }}{% else %}2026{% endif %} By the Campfire. Gather 'round.</p>
        </div>
    </footer>

    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
</body>
</html>
